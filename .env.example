# =====================================================================
# ÖRNEK ortam değişkenleri şablonu.
#
# Bu dosyayı '.env' olarak kopyalayın ve gerçek değerleri girin:
#     cp .env.example .env        (Linux/Mac)
#     copy .env.example .env      (Windows)
#
# .env dosyası .gitignore ile hariç tutulur — GERÇEK SECRET'LAR ORAYA
# YAZILIR, ASLA git'e girmez. Bu .example dosyası ise git'te durur ve
# yalnızca hangi değişkenlerin gerektiğini belgeler (secret içermez).
#
# Değişkenler DONATI_ önekiyle app/config.yaml'daki her ayarı ezer.
# =====================================================================

# Veri kaynağı: mock | serial
DONATI_VERI_KAYNAGI=mock

# Mock tarama süresi (saniye). Geliştirme/test için kısa tutun:
DONATI_MOCK_SURE_MIN_SN=3
DONATI_MOCK_SURE_MAKS_SN=5

# Pas payı "sınırda" görsel uyarı payı (mm)
DONATI_SINIRDA_PAY_MM=10

# Disk yönetimi
DONATI_MAKS_TARAMA_SAYISI=0
DONATI_UYARI_TARAMA_SAYISI=50

# PostgreSQL bağlantısı (async sürücü: postgresql+asyncpg://).
# ŞİFRE İÇERİR → gerçek değeri kopyaladığınız .env'e yazın, buraya DEĞİL.
# docker-compose içinde host "db" servis adıdır (bkz. Faz 3B).
DONATI_DB_URL=postgresql+asyncpg://donati:GERCEK_SIFRE@db:5432/donati

# SerialDataSource (yalnızca veri_kaynagi=serial iken)
DONATI_SERI_PORT=/dev/ttyACM0
DONATI_SERI_BAUD=921600
